datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Shop {
  id         String     @id @default(uuid())
  name       String
  address    String
  phone      String
  tgBotToken String     @default("")
  tgChatId   String     @default("")
  mode       String     @default("BOTH") // "UNIT_ONLY" | "QTY_ONLY" | "BOTH"
  users      User[]
  products   Product[]
  categories Category[]
  sales      Sale[]
  createdAt  DateTime   @default(now())
}

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  passwordHash  String
  plainPassword String   @default("") // Stored for super admin visibility
  pinCode       String   @default("") // 4-digit pin code stored in db
  role          String // "SUPER_ADMIN" | "ADMIN" | "CASHIER"
  fullName      String
  isBlocked     Boolean  @default(false)
  shopId        String? // nullable for SUPER_ADMIN
  shop          Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  sales         Sale[]
  createdAt     DateTime @default(now())
}

model Category {
  id        String    @id @default(uuid())
  name      String
  shopId    String
  shop      Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products  Product[]
  createdAt DateTime  @default(now())

  @@unique([name, shopId])
}

model Product {
  id           String     @id @default(uuid())
  barcode      String?
  name         String
  categoryId   String
  category     Category   @relation(fields: [categoryId], references: [id])
  shopId       String
  shop         Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  costPrice    Float // Tannarxi
  sellingPrice Float // Sotuv narxi
  stock        Float // Ombor miqdori
  unit         String // "dona" | "kg" | "metr"
  createdAt    DateTime   @default(now())
  saleItems    SaleItem[]

  @@unique([barcode, shopId])
}

model Sale {
  id             String     @id @default(uuid())
  cashierId      String
  cashier        User       @relation(fields: [cashierId], references: [id])
  shopId         String
  shop           Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  totalAmount    Float // Jami summa
  discountAmount Float      @default(0.0)
  paymentType    String // "CASH" | "CARD" (Qarz) | "CLICK_PAYME"
  receiptNumber  String
  customerName   String     @default("Xaridor")
  isDebtPaid     Boolean    @default(false)
  debtPaidAmount Float      @default(0.0)
  createdAt      DateTime   @default(now())
  items          SaleItem[]

  @@unique([receiptNumber, shopId])
}

model SaleItem {
  id           String   @id @default(uuid())
  saleId       String
  sale         Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  quantity     Float
  sellingPrice Float
  costPrice    Float
  total        Float
  createdAt    DateTime @default(now())
}

model CrowdsourcedBarcode {
  id        String   @id @default(uuid())
  barcode   String   @unique
  name      String
  shopName  String   @default("")
  createdAt DateTime @default(now())
}
